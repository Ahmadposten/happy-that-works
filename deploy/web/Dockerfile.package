# Package-only image: takes the PRE-BUILT Expo web export and serves it with
# nginx. The bundle is built beforehand in a plain node container (the
# Jenkins "Build web bundle" stage), NOT here — so kaniko only snapshots the
# small dist/ + config, never node_modules. This is the whole point: kaniko
# snapshotting a monorepo node_modules after each RUN was turning the build
# into a 40-minute job.
FROM nginx:alpine

# web-dist (not "dist") so the repo .dockerignore's `**/dist` rule doesn't
# strip it from the kaniko build context. node_modules stays excluded.
COPY packages/happy-app/web-dist /usr/share/nginx/html
COPY deploy/web/nginx-spa.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
