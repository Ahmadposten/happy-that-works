pipeline {
  // Reuses the same `eas` Jenkins agent pod template that benjamins-mobile
  // uses (Node + eas-cli). The happy app is a pnpm monorepo, so all EAS
  // commands run from packages/happy-app after a workspace install.
  agent { kubernetes { label 'eas'; defaultContainer 'jnlp' } }

  options {
    timeout(time: 180, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '10'))
    disableConcurrentBuilds()
  }

  environment {
    // These four credentials are the SAME ones benjamins-mobile already
    // uses. App Store Connect API keys are team-wide (not per-app), so the
    // existing key works for any app under Apple team H2XR8XWZXW. EXPO_TOKEN
    // must belong to the Expo account that owns the happy EAS project.
    EXPO_TOKEN         = credentials('expo-token')
    EXPO_ASC_KEY_ID    = credentials('asc-key-id')
    EXPO_ASC_ISSUER_ID = credentials('asc-issuer-id')
    EXPO_APPLE_TEAM_ID = 'H2XR8XWZXW'
    EXPO_APPLE_TEAM_TYPE = 'INDIVIDUAL'
    // Monorepo: EAS is driven from the app package.
    APP_DIR = 'packages/happy-app'
    // The eas-agent runs as non-root (uid 1000) with npm prefix /usr, so
    // `corepack enable` can't symlink pnpm into /usr/bin. Install the pnpm
    // shim into a writable dir and put it on PATH for every stage. Version
    // is pinned by the root package.json "packageManager": "pnpm@10.11.0".
    COREPACK_HOME = '/home/jenkins/.corepack'
    PATH = "/home/jenkins/.pnpm-bin:${PATH}"
  }

  stages {
    stage('Checkout') {
      options { retry(3) }
      steps { checkout scm }
    }

    stage('Install') {
      // Workspace install at the repo root. corepack installs the pnpm shim
      // into the writable /home/jenkins/.pnpm-bin (already on PATH via the
      // environment block) and activates the pinned 10.11.0, then installs.
      options { retry(3) }
      steps {
        sh '''
          mkdir -p /home/jenkins/.pnpm-bin
          corepack enable --install-directory /home/jenkins/.pnpm-bin pnpm
          corepack prepare pnpm@10.11.0 --activate
          # Install ONLY the happy-app subgraph. The repo .npmrc defaults to
          # node-linker=hoisted, which flattens every workspace dep to root
          # and builds codium's node-pty (needs `make`, absent here) even
          # with --filter. Override to isolated (exactly like
          # Dockerfile.webapp) so the filter truly excludes codium/node-pty.
          SKIP_HAPPY_WIRE_BUILD=1 pnpm install --frozen-lockfile --filter happy-app... \
            --config.node-linker=isolated --config.shamefully-hoist=false
          # happy-app's typecheck imports @slopus/happy-wire's built output.
          pnpm --filter @slopus/happy-wire build
        '''
      }
    }

    stage('Typecheck') {
      // Fast gate before spending a paid EAS build. tsc --noEmit.
      steps {
        dir("${APP_DIR}") {
          sh 'pnpm typecheck'
        }
      }
    }

    stage('EAS Build — iOS (production)') {
      // retry(1) is deliberate: each attempt is a real EAS build that
      // consumes paid build credits. The ASC .p8 is materialised from a
      // base64 Jenkins secret, used, then removed.
      options { retry(1) }
      steps {
        dir("${APP_DIR}") {
          withCredentials([string(credentialsId: 'asc-key-p8', variable: 'ASC_KEY_P8_B64')]) {
            sh '''
              echo "$ASC_KEY_P8_B64" | base64 -d > /tmp/asc-key.p8
              chmod 600 /tmp/asc-key.p8
              EXPO_ASC_API_KEY_PATH=/tmp/asc-key.p8 \
                eas build -p ios --profile production --non-interactive --wait
              rm -f /tmp/asc-key.p8
            '''
          }
        }
      }
    }

    stage('Submit to TestFlight') {
      options { retry(3) }
      steps {
        dir("${APP_DIR}") {
          withCredentials([string(credentialsId: 'asc-key-p8', variable: 'ASC_KEY_P8_B64')]) {
            sh '''
              echo "$ASC_KEY_P8_B64" | base64 -d > /tmp/asc-key.p8
              chmod 600 /tmp/asc-key.p8
              # APP_ENV=production so app.config.js resolves the production
              # bundle (com.ahposten.happyimproved) — without it, eas submit
              # defaults to APP_ENV=development, targets the .dev bundle, and
              # then fails trying to set up ASC credentials non-interactively.
              APP_ENV=production EXPO_ASC_API_KEY_PATH=/tmp/asc-key.p8 \
                eas submit -p ios --profile production --latest --non-interactive --no-wait
              rm -f /tmp/asc-key.p8
            '''
          }
        }
      }
    }
  }

  post { always { cleanWs() } }
}
