{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "development-store": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "store",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "preview-store": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
